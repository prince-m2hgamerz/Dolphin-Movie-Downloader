# TPB_API_MIRRORS=https://apibay.org,https://pirateproxy.live,https://apibay.net
# Optional provider order override (comma-separated)
# SEARCH_PROVIDER_ORDER=Yts,ThePirateBay,TorrentProject,1337x,Eztv,Limetorrents,KickassTorrents,Torrentz2,Torrent9,Rarbg

# -----------------------------
# Vercel API proxy settings
# -----------------------------
