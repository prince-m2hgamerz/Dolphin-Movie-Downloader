# -----------------------------
PORT=80
HOST=0.0.0.0
PUBLIC_BASE_URL=http://3.25.133.248
SERVER_DOWNLOAD_PATH=./downloads
COMPLETED_TTL_MS=0
STALL_RESTART_MS=180000
MAX_STALL_RESTARTS=8
STALL_MIN_PROGRESS_BYTES=32768
