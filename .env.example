# -----------------------------
# EC2 / Node server settings
# -----------------------------
PORT=3000
SERVER_DOWNLOAD_PATH=./downloads
COMPLETED_TTL_MS=0
STALL_RESTART_MS=180000
MAX_STALL_RESTARTS=3

# -----------------------------
# Vercel API proxy settings
# -----------------------------
# Use base URL only (no trailing /api)
API_BASE_URL_PRODUCTION=https://api.vibexmovie.vercel.app
API_BASE_URL_PREVIEW=https://staging-api.vibexmovie.vercel.app
API_BASE_URL_DEVELOPMENT=https://dev-api.vibexmovie.vercel.app

# Optional generic fallback (used if env-specific variable is missing)
API_BASE_URL=https://vibexmovie.vercel.app/

# Optional alias fallback names (leave empty unless needed)
EC2_API_BASE_URL=
EC2_API_URL=
UPSTREAM_API_BASE_URL=
BACKEND_API_BASE_URL=
