{
  "name": "dolphin-movie-downloader",
  "version": "1.1.3",
  "repository": "https://github.com/GHDBASHEN/Dolphin-Movie-Downloader",
  "description": "Free Desktop Movie Downloader",
  "main": "src/main.js",
  "author": "Ghdb Ashen",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "server:start": "node server.js",
    "ec2:start": "node server.js",
    "web:test": "node scripts/test-api.js",
    "web:check": "node --check server.js && node --check src/web-api.js && node --check src/renderer.js"
  },
  "build": {
    "appId": "com.moviedownloader.app",
     "publish": [
      {
        "provider": "github",
        "owner": "GHDBASHEN",
        "repo": "Dolphin-Movie-Downloader"
      }
    ],
    "productName": "Dolphin Movie Downloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "publish": [ "github" ],
      "icon": "icon.ico"
    },
    "linux": {
      "target": ["AppImage"], 
      "icon": "icon.png",
      "category": "Video"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.entertainment",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "icon": "icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "torrent-search-api": "^2.1.4",
    "webtorrent": "1.9.7"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^24.13.3"
  }
}
